# QSCM local environment example
#
# Copy this file to .env.local for local development. Leave secrets blank here;
# real values belong in local password storage, Vercel project settings, or
# GitHub Actions secrets.

# Public site URL used by local smoke checks and future absolute URL generation.
# Local: http://localhost:3000
# Preview: Vercel-provided preview URL
# Production: https://qscm-website.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional local Vercel CLI defaults. These are not application runtime values.
# GitHub Actions requires these as repository secrets for preview and production
# deploys; local developers can also authenticate with `vercel login`.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

# Future database-backed features are tracked in GitHub issue #151. Do not add
# production database credentials until the migration command and rollback
# policy are defined.
# DATABASE_URL=
